{
  "name": "@homeshare/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "process:platform-fees": "pnpm build && node scripts/process-platform-fee-intents.mjs",
    "process:platform-fees:watch": "pnpm build && PLATFORM_FEE_INTENT_CONTINUOUS=true node scripts/process-platform-fee-intents.mjs",
    "process:properties": "pnpm build && node scripts/process-property-intents.mjs",
    "process:properties:watch": "pnpm build && PROPERTY_INTENT_CONTINUOUS=true node scripts/process-property-intents.mjs",
    "process:profits": "pnpm build && node scripts/process-profit-intents.mjs",
    "process:profits:watch": "pnpm build && PROFIT_INTENT_CONTINUOUS=true node scripts/process-profit-intents.mjs",
    "process:indexer": "pnpm build && node scripts/process-indexer-sync.mjs",
    "process:indexer:watch": "pnpm build && INDEXER_CONTINUOUS=true node scripts/process-indexer-sync.mjs",
    "process:campaign-lifecycle": "pnpm build && node scripts/process-campaign-lifecycle.mjs",
    "process:campaign-lifecycle:watch": "pnpm build && CAMPAIGN_LIFECYCLE_CONTINUOUS=true node scripts/process-campaign-lifecycle.mjs",
    "process:intents:watch": "pnpm build && node scripts/start-intent-workers.mjs",
    "process:intents:watch:runtime": "node scripts/start-intent-workers.mjs",
    "agent:run": "node scripts/agent-runtime.mjs",
    "migrate:profit-distributors": "pnpm build && node scripts/migrate-profit-distributors.mjs",
    "indexer:sync": "node --import tsx src/indexer/run.ts",
    "indexer:sync:tx": "pnpm build && node scripts/indexer-sync-tx.mjs",
    "backfill:profit-distributors": "pnpm build && node scripts/backfill-profit-distributor-mappings.mjs",
    "profit:check-flow": "pnpm build && node scripts/check-profit-flow.mjs",
    "reconcile:properties": "pnpm build && node scripts/reconcile-property-intents.mjs",
    "reconcile:profits": "pnpm build && node scripts/reconcile-profit-intents.mjs",
    "reconcile:platform-fees": "pnpm build && node scripts/reconcile-platform-fee-intents.mjs",
    "reconcile:intents": "pnpm build && node scripts/reconcile-intents.mjs",
    "intents:manage": "pnpm build && node scripts/manage-intents.mjs",
    "intents:alert": "pnpm build && node scripts/alert-intents.mjs",
    "observability:snapshot": "pnpm build && node scripts/observability-snapshot.mjs",
    "lint": "eslint . --ext .ts",
    "test": "pnpm build && node scripts/test-v1.mjs",
    "check:v1": "tsx scripts/check-v1.ts"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.45.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "bull": "^4.11.5",
    "axios": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/supertest": "^2.0.16",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
